# =============================================================================
# 1. Configuración Principal del Sistema
# =============================================================================
APP_NAME=Gelia-NV
APP_ENV=production
APP_KEY=base64:r4HkP5mRwOTzP++41tmWqKdDedDoQkteRYd1akIYnoM=
APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# =============================================================================
# 2. Configuración de Trazabilidad y Logs
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# 3. Conexión a Base de Datos Principal
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gelia_nv
DB_USERNAME=ti_admin_aromas
DB_PASSWORD=?82&7HHVb*c

# =============================================================================
# 4. Redis: Optimización de Caché, Colas y Sesiones
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=public

# =============================================================================
# 5. Laravel Reverb (WebSockets & Broadcasting)
# =============================================================================
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=gelia_app_id
REVERB_APP_KEY=reverb_key_gelia
REVERB_APP_SECRET=tu_secreto

# El contenedor de Reverb debe escuchar en todas las interfaces para recibir a Cloudflare
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Estas variables indican al cliente (Vite/React) a dónde conectarse externamente
REVERB_HOST=gelianv.neobash.site
REVERB_PORT=443
REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# =============================================================================
# 6. Servicios de Correo Electrónico (SMTP)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="contacto.neobahs@gmail.com"
MAIL_PASSWORD="INGRESAR_NUEVA_CONTRASENA"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contacto.neobahs@gmail.com"
MAIL_FROM_NAME="GELIA - Notificaciones"

# =============================================================================
# 7. Cloudflare Tunnel
